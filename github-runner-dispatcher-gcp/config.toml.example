[[label]]
name                       = "sockerless-cloudrun"
gcp_project                = "sockerless-live-46x3zg4imo"
gcp_region                 = "us-central1"
image                      = "us-central1-docker.pkg.dev/sockerless-live-46x3zg4imo/sockerless-live/runner:cloudrun-amd64"
service_account            = "sockerless-runner@sockerless-live-46x3zg4imo.iam.gserviceaccount.com"
runner_workspace_bucket    = "sockerless-live-46x3zg4imo-runner-workspace"
# Phase 123: "gcs-sync" leaves the runner-task tmpfs and propagates
# workspace via GCS SDK at exec boundaries. Required when bucket is set.
# "gcs-fuse" is the legacy direct-mount mode (cells 7+8 tar-pack persist).
runner_workspace_backing   = "gcs-sync"

[[label]]
name                       = "sockerless-gcf"
gcp_project                = "sockerless-live-46x3zg4imo"
gcp_region                 = "us-central1"
image                      = "us-central1-docker.pkg.dev/sockerless-live-46x3zg4imo/sockerless-live/runner:gcf-amd64"
service_account            = "sockerless-runner@sockerless-live-46x3zg4imo.iam.gserviceaccount.com"
runner_workspace_bucket    = "sockerless-live-46x3zg4imo-runner-workspace"
runner_workspace_backing   = "gcs-sync"
